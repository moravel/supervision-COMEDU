# ========================================
# .gitignore - Projet Supervision COMEDU
# ========================================

# --- Exécutables et binaires ---
*.exe
*.msi
*.dll
*.so
*.dylib

# --- Archives et fichiers compressés ---
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# --- Certificats et clés (SÉCURITÉ) ---
server.key
server.crt
transport.key
*.pem
*.pfx
*.p12

# --- Variables d'environnement ---
.env
.env.*

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# --- Environnements virtuels Python ---
env/
venv/
.venv/

# --- PyInstaller (build du client) ---
sources_client/build/
sources_client/dist/

# --- Données dynamiques du serveur ---
server/data/
server/uploads/
server/client_binaries/

# --- Dossier client_windows (contient l'exe compilé) ---
client_windows/

# --- Logs et bases ---
*.log
*.sqlite

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
